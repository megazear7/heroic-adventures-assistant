              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "For unclear interactions, apply the narrowest bypass interpretation.",
                        "marks": [],
                        "data": {}
                      }
                    ]
