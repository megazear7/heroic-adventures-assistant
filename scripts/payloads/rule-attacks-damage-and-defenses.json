            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Rule: Attacks, Damage, and Defenses",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Scope",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Use this rule for all attack resolution, hit/miss logic, damage calculation, and defense mitigation.",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Consolidated Rule",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Most attacks are opposed d20 rolls: attacker adds attack stat, defender adds defense stat. If attacker total exceeds defender total, attack hits.",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Default stat pairing:",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "unordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "weapon attacks: attacker skill vs defender agility",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "spell attacks: attacker intelligence vs defender willpower",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Then resolve block/cover/toughness modifiers and compute damage.",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Resolution Procedure",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "ordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Determine attack type (melee/ranged/spell/feature).",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Check special clauses (ignore shields, ignore armor, ignore toughness).",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Roll opposed d20s and add modifiers.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "If hit: roll damage dice and add damage modifiers.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Apply melee strength bonus where applicable.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Subtract toughness unless bypassed.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Apply remaining damage to temporary health first, then current health.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
