                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Damage dice explode on max result repeatedly.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Advantage provides +2 and does not stack above +2.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Temporary health does not stack; keep higher value only.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Adjudication Notes",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "unordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Resolve hit determination before any damage manipulation.",
                        "marks": [],
                        "data": {}
