              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Track whether a rule says ignore shields, ignore armor, or ignore damage reduction; these are different.",
