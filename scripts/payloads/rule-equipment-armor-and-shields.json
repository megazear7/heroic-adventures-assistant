                "data": {}
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Armor converts mobility/defense tradeoff into toughness. Shields add block and initiative penalties. Grades and magical versions scale item power and economy cost.",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Armor Core Mechanics",
