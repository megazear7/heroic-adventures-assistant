              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Toughness directly reduces incoming damage unless bypassed.",
