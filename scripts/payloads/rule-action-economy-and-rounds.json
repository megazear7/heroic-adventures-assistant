              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Scope",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Use this rule for complete turn-timing adjudication in combat:",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "unordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "card-flip activation timing",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "what action types are legal at each timing window",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "per-round/per-card limits",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "conflicts between reactions, opportunity actions, and bonus actions",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Consolidated Rule",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Combat runs on a 10-card encounter deck per level band. Each card flip opens an activation window for creatures in the shown initiative range (or all creatures on the all-players/all-monsters cards). During legal activation, creatures can use action types as follows:",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "unordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Major action",
                        "marks": [
                          {
                            "type": "bold"
                          }
                        ],
                        "data": {}
                      },
                      {
                        "nodeType": "text",
                        "value": ": core turn action; most creatures get at most one major action per round.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Minor action",
                        "marks": [
                          {
                            "type": "bold"
                          }
                        ],
                        "data": {}
                      },
                      {
                        "nodeType": "text",
                        "value": ": utility/mobility/support actions; available when timing and action choice allow.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Heroic action",
                        "marks": [
                          {
                            "type": "bold"
                          }
                        ],
                        "data": {}
                      },
                      {
                        "nodeType": "text",
                        "value": ": special high-impact actions gated by heroic action uses per day, unless overridden by effects (for example bravery potions).",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Bonus action",
                        "marks": [
                          {
                            "type": "bold"
                          }
                        ],
                        "data": {}
                      },
                      {
                        "nodeType": "text",
                        "value": ": available when the currently flipped range is higher than the previous range, or when a range card is first flipped in round 1 of that round.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Reaction",
                        "marks": [
                          {
                            "type": "bold"
                          }
                        ],
                        "data": {}
                      },
                      {
                        "nodeType": "text",
                        "value": ": triggered by feature text; limited to one reaction per initiative card.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Opportunity action",
                        "marks": [
                          {
                            "type": "bold"
                          }
                        ],
                        "data": {}
                      },
                      {
                        "nodeType": "text",
                        "value": ": triggered primarily by enemy major movement leaving melee threat.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Round Procedure",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "ordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Build and shuffle encounter deck.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Flip one card at a time.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Activate matching creatures; they take legal actions for that window.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Resolve triggered reactions/opportunity actions immediately when triggers occur.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Continue until all 10 cards resolve.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "End round, then reshuffle and start next round if combat continues.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Key Interactions",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "unordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Surprise causes affected creatures to skip their first initiative card in round 1.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Heroic actions generally permit major movement and consume heroic resources.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "A creature can only use one reaction per initiative card, even if multiple triggers occur.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Opportunity actions depend on threatened positioning and major movement, not minor movement.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Bonus action availability is card-order dependent, not creature-choice dependent.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Adjudication Notes",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "unordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Resolve action legality first, then dice/mechanical outcomes.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "If multiple triggers fire simultaneously, resolve in initiative-owner order unless a specific feature states otherwise.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "When uncertain, prefer the more restrictive timing interpretation and communicate clearly to players.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  }
}