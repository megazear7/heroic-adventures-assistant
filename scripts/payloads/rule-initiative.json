            "content": [
              {
                "nodeType": "text",
                "value": "Rule: Initiative",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Scope",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Use this rule for initiative values, encounter deck windows, tie behavior, and when initiative changes take effect.",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Consolidated Rule",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Initiative determines which encounter deck range activates a creature. Cards are range-based, not single-value sequencing. When a range card flips, all creatures in that range can act according to action economy rules.",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Setup and Activation",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "ordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Determine encounter level band.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Build 10-card encounter deck for that band.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Shuffle and flip cards sequentially.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "On each range card, activate all matching creatures.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "If multiple creatures share initiative:",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "unordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "enemy groups can activate one-by-one on that card,",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "players with identical initiative can resolve in clockwise order or any agreed player order.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Surprise and Skips",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Surprised creatures skip their first initiative card in the first combat round only.",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Initiative Modification",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "unordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Equipment and training can alter effective initiative.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
