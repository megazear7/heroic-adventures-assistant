                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Initiative bonuses from training apply per trained weapon category when using that category.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Adjudication Notes",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "unordered-list",
            "data": {},
            "content": [
              {
                "nodeType": "list-item",
