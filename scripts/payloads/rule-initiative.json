                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Initiative windows are card-driven; do not convert to strict descending initiative count.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "If a creature\u2019s initiative changes mid-round, apply at next round unless a rule explicitly says immediate.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Keep initiative cards visible to avoid timing disputes.",
