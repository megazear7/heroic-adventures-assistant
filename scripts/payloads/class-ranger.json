            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Make an initiative vs. initiative attack against your prey and add to your attack roll equal to the number of hunting points you have.",
                "marks": [],
                "data": {}
              }
            ]
