                "data": {}
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Make an initiative vs. initiative attack against your prey and add damage to the attack equal to the number of hunting points you have.",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "heading-3",
