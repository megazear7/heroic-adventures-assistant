          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Each time you target a creature with an attack, that creature is now your prey, and you gain 1 hunting point, up to a maximum of 3. If you attack a different target before the original target is killed, then prior to making the attack, your hunting points are reduced to 0 and the new target is now your prey.",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
