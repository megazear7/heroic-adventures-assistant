          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Consolidated Rule",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Consumables are limited by ready-access slots and action timing, while loot scales by encounter difficulty and level pressure. Economy is a balance lever for survivability, gear progression, and resource attrition.",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "heading-2",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Consumables Handling",
