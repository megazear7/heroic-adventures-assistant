            "data": {},
            "content": [
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Ready access: up to 4 consumable types, up to 4 quantity each.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Most use minor actions; some use reactions if text permits.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "One consumable use per action.",
                        "marks": [],
                        "data": {}
                      }
                    ]
                  }
                ]
              },
              {
                "nodeType": "list-item",
                "data": {},
                "content": [
                  {
                    "nodeType": "paragraph",
                    "data": {},
                    "content": [
                      {
                        "nodeType": "text",
                        "value": "Refill from inventory out of combat with time.",
