              }
            ]
          },
          {
            "nodeType": "paragraph",
            "data": {},
            "content": [
              {
                "nodeType": "text",
                "value": "Spend 1 fury dice and make two attacks, one with your primary weapon and one with your secondary weapon.",
                "marks": [],
                "data": {}
              }
            ]
          },
          {
            "nodeType": "heading-3",
